#!/usr/bin/env bun
import { existsSync, realpathSync } from "node:fs";
import { dirname, join } from "node:path";

const scriptPath = realpathSync(import.meta.path);
const root = dirname(dirname(scriptPath));
const command = Bun.argv[2] ?? "";

function usage() {
  console.log(`ui - living browser style reference

Usage:
  ui                 start the main web site at http://localhost:3000/
  ui help            show this message`);
}

async function run(command) {
  const proc = Bun.spawn(command, {
    cwd: root,
    stdin: "inherit",
    stdout: "inherit",
    stderr: "inherit",
  });

  const code = await proc.exited;
  if (code !== 0) {
    process.exit(code);
  }
}

async function installWebDeps() {
  if (!existsSync(join(root, "node_modules"))) {
    console.log("-> installing web deps with bun");
    await run(["bun", "install"]);
  }
}

async function runWeb() {
  await installWebDeps();
  console.log("-> web site: http://localhost:3000/");
  await run(["bun", "--hot", "server.ts"]);
}

switch (command) {
  case "":
    await runWeb();
    break;
  case "help":
  case "-h":
  case "--help":
    usage();
    break;
  default:
    usage();
    process.exit(1);
}
