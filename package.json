{
  "name": "ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/ui.es.js",
  "module": "./dist/ui.es.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md",
    "docs",
    "!docs/handoff.md"
  ],
  "bin": {
    "ui": "./bin/ui.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./dist/ui.css": {
      "types": "./dist/ui.d.css.ts",
      "default": "./dist/ui.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "demo": "bun ./bin/ui.mjs demo",
    "build": "vite build && tsc -p tsconfig.build.json && node scripts/write-css-dts.mjs",
    "typecheck": "tsc -b --noEmit",
    "test": "bun test",
    "lint": "eslint src examples design-lab tests"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.0.0",
    "bun-types": "^1.3.13",
    "dxf-viewer": "^1.0.47",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jsdom": "^29.1.1",
    "occt-import-js": "^0.0.23",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-texmath": "^1.0.0"
  }
}
